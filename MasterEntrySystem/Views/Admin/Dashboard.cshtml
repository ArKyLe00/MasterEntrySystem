@using MasterEntrySystem.Models
@{
    ViewData["Title"] = "Admin Dashboard";
    var workers = ViewBag.Workers as List<AppUser>;
    var taskAssignments = ViewBag.TaskAssignments as List<TaskAssignment>;
}

<div class="dashboard-container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="dashboard-title">Admin Dashboard</h1>
        <button class="btn btn-primary premium-btn" data-bs-toggle="modal" data-bs-target="#assignTaskModal">
            <i class="bi bi-plus-circle"></i> Assign New Task
        </button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- ===================== MANAGE WORKERS SECTION ===================== -->
    <div class="card premium-card shadow-sm mb-5">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-1"><i class="bi bi-people-fill me-2 text-primary"></i>Manage Workers</h5>
                <p class="text-muted small mb-0">Add, edit, and manage your team members</p>
            </div>
            <button class="btn btn-success premium-btn-success" data-bs-toggle="modal" data-bs-target="#addWorkerModal">
                <i class="bi bi-person-plus-fill me-1"></i> Add Worker
            </button>
        </div>
        <div class="card-body">
            @if (workers != null && workers.Any())
            {
                <!-- Stats Row -->
                <div class="row mb-4">
                    <div class="col-md-4">
                        <div class="stat-mini-card stat-active">
                            <div class="stat-mini-icon"><i class="bi bi-check-circle-fill"></i></div>
                            <div>
                                <div class="stat-mini-value">@workers.Count(w => w.Status == "Active")</div>
                                <div class="stat-mini-label">Active</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stat-mini-card stat-inactive">
                            <div class="stat-mini-icon"><i class="bi bi-pause-circle-fill"></i></div>
                            <div>
                                <div class="stat-mini-value">@workers.Count(w => w.Status == "Inactive")</div>
                                <div class="stat-mini-label">Inactive</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stat-mini-card stat-disabled">
                            <div class="stat-mini-icon"><i class="bi bi-x-circle-fill"></i></div>
                            <div>
                                <div class="stat-mini-value">@workers.Count(w => w.Status == "Disabled")</div>
                                <div class="stat-mini-label">Disabled</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle custom-table" id="workersTable">
                        <thead class="table-light">
                            <tr>
                                <th>Worker</th>
                                <th>Department</th>
                                <th>Designation</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var worker in workers)
                            {
                                <tr class="worker-row @(worker.Status == "Disabled" ? "row-disabled" : "")">
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle me-3 @(worker.Status == "Active" ? "" : "avatar-muted")">
                                                @(worker.Name.Substring(0, 1).ToUpper())
                                            </div>
                                            <div>
                                                <div class="fw-bold">@worker.Name</div>
                                                <div class="text-muted small">@worker.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(worker.Department))
                                        {
                                            <span class="badge bg-light text-dark border">@worker.Department</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic small">Not set</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(worker.Designation))
                                        {
                                            <span>@worker.Designation</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic small">Not set</span>
                                        }
                                    </td>
                                    <td>
                                        @if (worker.Status == "Active")
                                        {
                                            <span class="badge status-badge status-active"><i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>Active</span>
                                        }
                                        else if (worker.Status == "Inactive")
                                        {
                                            <span class="badge status-badge status-inactive"><i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>Inactive</span>
                                        }
                                        else
                                        {
                                            <span class="badge status-badge status-disabled"><i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>Disabled</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary me-1 btn-action"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editWorkerModal"
                                                data-id="@worker.Id"
                                                data-name="@worker.Name"
                                                data-email="@worker.Email"
                                                data-department="@worker.Department"
                                                data-designation="@worker.Designation"
                                                data-status="@worker.Status"
                                                title="Edit">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <form asp-action="DeleteWorker" asp-controller="Admin" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this worker? This will also delete all their task assignments.');">
                                            <input type="hidden" name="id" value="@worker.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger btn-action" title="Delete">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-people" style="font-size: 3rem;"></i>
                    <p class="mt-3">No workers have been added yet.</p>
                    <button class="btn btn-primary premium-btn mt-2" data-bs-toggle="modal" data-bs-target="#addWorkerModal">
                        <i class="bi bi-person-plus-fill me-1"></i> Add Your First Worker
                    </button>
                </div>
            }
        </div>
    </div>

    <!-- ===================== TASK ASSIGNMENTS SECTION ===================== -->
    <div class="card premium-card shadow-sm mb-5">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
            <h5 class="mb-0"><i class="bi bi-clipboard-check me-2 text-primary"></i>Current Task Assignments</h5>
        </div>
        <div class="card-body">
            @if (taskAssignments != null && taskAssignments.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle custom-table">
                        <thead class="table-light">
                            <tr>
                                <th>Worker</th>
                                <th>Task Name</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var assignment in taskAssignments)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle me-3">
                                                @(assignment.Worker?.Name.Substring(0, 1).ToUpper() ?? "U")
                                            </div>
                                            <div>
                                                <div class="fw-bold">@assignment.Worker?.Name</div>
                                                <div class="text-muted small">@assignment.Worker?.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-primary rounded-pill px-3 py-2 task-badge">@assignment.TaskName</span></td>
                                    <td>@assignment.StartDate.ToShortDateString()</td>
                                    <td>@assignment.EndDate.ToShortDateString()</td>
                                    <td>
                                        @if (assignment.EndDate < DateTime.Now)
                                        {
                                            <span class="badge bg-secondary">Completed</span>
                                        }
                                        else if (assignment.StartDate > DateTime.Now)
                                        {
                                            <span class="badge bg-warning text-dark">Upcoming</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">In Progress</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-clipboard-x" style="font-size: 3rem;"></i>
                    <p class="mt-3">No tasks have been assigned yet.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- ===================== ADD WORKER MODAL ===================== -->
<div class="modal fade" id="addWorkerModal" tabindex="-1" aria-labelledby="addWorkerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content premium-modal">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold" id="addWorkerModalLabel">
                    <i class="bi bi-person-plus-fill me-2 text-success"></i>Add New Worker
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="AddWorker" asp-controller="Admin" method="post">
                <div class="modal-body pt-3">
                    <div class="mb-3">
                        <label for="workerName" class="form-label"><i class="bi bi-person me-1"></i>Full Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control premium-input" id="workerName" name="name" required placeholder="John Doe">
                    </div>
                    <div class="mb-3">
                        <label for="workerEmail" class="form-label"><i class="bi bi-envelope me-1"></i>Email Address <span class="text-danger">*</span></label>
                        <input type="email" class="form-control premium-input" id="workerEmail" name="email" required placeholder="john.doe@example.com">
                    </div>
                    <div class="mb-3">
                        <label for="workerPassword" class="form-label"><i class="bi bi-lock me-1"></i>Password <span class="text-danger">*</span></label>
                        <input type="password" class="form-control premium-input" id="workerPassword" name="password" required placeholder="••••••••">
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="workerDepartment" class="form-label"><i class="bi bi-building me-1"></i>Department</label>
                            <input type="text" class="form-control premium-input" id="workerDepartment" name="department" placeholder="e.g. Engineering">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="workerDesignation" class="form-label"><i class="bi bi-briefcase me-1"></i>Designation</label>
                            <input type="text" class="form-control premium-input" id="workerDesignation" name="designation" placeholder="e.g. Developer">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="workerStatus" class="form-label"><i class="bi bi-toggle-on me-1"></i>Status</label>
                        <select class="form-select premium-input" id="workerStatus" name="status">
                            <option value="Active" selected>Active</option>
                            <option value="Inactive">Inactive</option>
                            <option value="Disabled">Disabled</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success premium-btn-success px-4">
                        <i class="bi bi-person-plus-fill me-1"></i>Add Worker
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ===================== EDIT WORKER MODAL ===================== -->
<div class="modal fade" id="editWorkerModal" tabindex="-1" aria-labelledby="editWorkerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content premium-modal">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold" id="editWorkerModalLabel">
                    <i class="bi bi-pencil-square me-2 text-primary"></i>Edit Worker
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="EditWorker" asp-controller="Admin" method="post">
                <input type="hidden" name="id" id="editWorkerId" />
                <div class="modal-body pt-3">
                    <div class="mb-3">
                        <label for="editWorkerName" class="form-label"><i class="bi bi-person me-1"></i>Full Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control premium-input" id="editWorkerName" name="name" required>
                    </div>
                    <div class="mb-3">
                        <label for="editWorkerEmail" class="form-label"><i class="bi bi-envelope me-1"></i>Email Address <span class="text-danger">*</span></label>
                        <input type="email" class="form-control premium-input" id="editWorkerEmail" name="email" required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="editWorkerDepartment" class="form-label"><i class="bi bi-building me-1"></i>Department</label>
                            <input type="text" class="form-control premium-input" id="editWorkerDepartment" name="department">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="editWorkerDesignation" class="form-label"><i class="bi bi-briefcase me-1"></i>Designation</label>
                            <input type="text" class="form-control premium-input" id="editWorkerDesignation" name="designation">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="editWorkerStatus" class="form-label"><i class="bi bi-toggle-on me-1"></i>Status</label>
                        <select class="form-select premium-input" id="editWorkerStatus" name="status">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                            <option value="Disabled">Disabled</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary premium-btn px-4">
                        <i class="bi bi-check-lg me-1"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ===================== ASSIGN TASK MODAL ===================== -->
<div class="modal fade" id="assignTaskModal" tabindex="-1" aria-labelledby="assignTaskModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content premium-modal">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold" id="assignTaskModalLabel">Assign Task to Worker</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="AssignTask" asp-controller="Admin" method="post">
                <div class="modal-body pt-3">
                    <div class="mb-3">
                        <label for="workerId" class="form-label">Select Worker</label>
                        <select class="form-select premium-input" id="workerId" name="workerId" required>
                            <option value="">Choose a worker...</option>
                            @if (workers != null)
                            {
                                @foreach (var worker in workers.Where(w => w.Status == "Active"))
                                {
                                    <option value="@worker.Id">@worker.Name (@worker.Email)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="taskName" class="form-label">Task Name</label>
                        <input type="text" class="form-control premium-input" id="taskName" name="taskName" placeholder="e.g. Task 1, Task 2" required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="startDate" class="form-label">Start Date</label>
                            <input type="date" class="form-control premium-input" id="startDate" name="startDate" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="endDate" class="form-label">End Date</label>
                            <input type="date" class="form-control premium-input" id="endDate" name="endDate" required>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary premium-btn px-4">Assign Task</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Auto-set the start and end dates to next week as a default
            const startDateInput = document.getElementById('startDate');
            const endDateInput = document.getElementById('endDate');
            
            const today = new Date();
            const nextMonday = new Date(today);
            nextMonday.setDate(today.getDate() + (1 + 7 - today.getDay()) % 7); // Next Monday
            
            if (nextMonday.getTime() < today.getTime()) {
                nextMonday.setDate(today.getDate() + 1); // fallback
            }

            const nextSunday = new Date(nextMonday);
            nextSunday.setDate(nextMonday.getDate() + 6); // Next Sunday

            startDateInput.value = nextMonday.toISOString().split('T')[0];
            endDateInput.value = nextSunday.toISOString().split('T')[0];

            // Populate Edit Worker modal with data from the clicked row
            const editWorkerModal = document.getElementById('editWorkerModal');
            editWorkerModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                document.getElementById('editWorkerId').value = button.getAttribute('data-id');
                document.getElementById('editWorkerName').value = button.getAttribute('data-name');
                document.getElementById('editWorkerEmail').value = button.getAttribute('data-email');
                document.getElementById('editWorkerDepartment').value = button.getAttribute('data-department') || '';
                document.getElementById('editWorkerDesignation').value = button.getAttribute('data-designation') || '';
                document.getElementById('editWorkerStatus').value = button.getAttribute('data-status') || 'Active';
            });
        });
    </script>
}
